{
	# Local admin API
	admin localhost:2019

	# Debug logging
	debug

	# this disables the automatic :80 listener, which is useless on dev
	auto_https disable_redirects

	# Configure certmatic
	certmatic {
		domain_store sqlite://./certmatic-dev.db
		session_store sqlite://./certmatic-dev.db
		# For local test with rqlite:
		# domain_store rqlite://localhost:4001?disableClusterDiscovery=true
		# session_store rqlite://localhost:4001?disableClusterDiscovery=true

		challenge_type http-01
		# challenge_type dns-01
		# dns_delegation_domain _acme-challenge.example.com

		cname_target dispatcher.linki.la
		portal_base_url http://localhost:33001/portal
		webhook_dispatcher memory {
			url http://localhost:33001/webhook-echo
		}

		# By default, certmatic will serve the portal UI assets from embedded resources.
		# For development, you can specify a directory to serve assets from.
		# (This is also useful if you want to use an alternative build of the portal UI, e.g. from a fork or branch.)
		portal_assets_dir ./portal/ui/dev-build
	}

	# On-demand TLS: certmatic_ask authorizes certificate issuance
	on_demand_tls {
		ask http://localhost:33001/ask
	}

	local_certs
}

# sanity check
:33443 {
	tls {
		on_demand
	}
	# return the host name in the body
	respond "{http.request.host}" 200
}

# certmatic admin + portal
:33001 {
	handle_path /admin/* {
		certmatic_admin
	}

	# on-demand TLS ask endpoint — keep this on an internal/localhost listener
	handle_path /ask {
		certmatic_ask
	}

	handle_path /portal/* {
		certmatic_portal
	}

	# Webhook echo endpoint — echoes the request body back as the response.
	handle_path /webhook-echo {
		respond "{http.request.body}" 200
	}
}
