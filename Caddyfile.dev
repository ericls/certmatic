{
	# Local admin API
	admin localhost:2019

	# Debug logging
	debug

	# Configure certmatic
	certmatic {
		domain_store sqlite://./certmatic-dev.db
		session_store sqlite://./certmatic-dev.db
		challenge_type http-01
		# challenge_type dns-01
		# dns_delegation_domain _acme-challenge.example.com
		cname_target dispatcher.linki.la
		portal_base_url http://localhost:33001/portal
		portal_dev_mode
		webhook_dispatcher memory {
			url http://localhost:33001/webhook-echo
		}
	}

	# On-demand TLS: certmatic_ask authorizes certificate issuance
	on_demand_tls {
		ask http://localhost:33001/ask
	}

	local_certs
}

# sanity check
:33443 {
	tls {
		on_demand
	}
	# return the host name in the body
	respond "{http.request.host}" 200
}

# certmatic admin + portal
:33001 {
	handle_path /admin/* {
		certmatic_admin
	}

	# on-demand TLS ask endpoint — keep this on an internal/localhost listener
	handle /ask {
		certmatic_ask
	}

	handle_path /portal/* {
		certmatic_portal
	}

	# Webhook echo endpoint — echoes the request body back as the response.
	handle /webhook-echo {
		respond "{http.request.body}" 200
	}

	# In dev, Caddy proxies /web_client/* directly to the Vite dev server.
	# In production, replace this block with: handle_path /web_client/portal/* { certmatic_portal_assets }
	handle /web_client/* {
		reverse_proxy localhost:5173
	}
}
